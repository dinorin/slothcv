{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SlothCV",
  "version": "0.2.0",
  "identifier": "com.slothcv.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Sloth CV",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "visible": false,
        "devtools": true
      },
      {
        "label": "splashscreen",
        "title": "Starting Sloth CV",
        "url": "splashscreen.html",
        "width": 360,
        "height": 240,
        "decorations": false,
        "resizable": false,
        "center": true,
        "transparent": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "devtools": {}
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
